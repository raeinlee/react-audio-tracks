{
  "name": "react-audio-tracks",
  "version": "1.2.10",
  "description": "A light-weight solution to manage audio tracks and captions in front-end web projects. Provides a handy custom react hook.",
  "license": "MIT",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsup index.ts --format cjs,esm --dts --external react",
    "test": "vitest run",
    "test:watch": "vitest",
    "release": "pnpm test && pnpm run build && changeset publish",
    "export-module": "module-export.bat",
    "lint": "tsc"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/raeinlee/react-audio-tracks.git",
    "demo": "https://react-audio-tracks.vercel.app"
  },
  "author": "Raein Lee <a.lee.intl@gmail.com> (https://github.com/raeinlee)",
  "bugs": {
    "url": "https://github.com/raeinlee/react-audio-tracks/issues"
  },
  "homepage": "https://github.com/raeinlee/react-audio-tracks#readme",
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "keywords": [
    "react",
    "audio",
    "track",
    "audio tracks",
    "react-audio-tracks"
  ],
  "peerDependencies": {
    "react": ">=18.0.0"
  },
  "devDependencies": {
    "@changesets/cli": "^2.26.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^14.3.1",
    "@types/react": "^18.0.35",
    "@types/react-dom": "^18.3.7",
    "jsdom": "^29.0.2",
    "prettier": "^3.0.3",
    "react": "^18.2.0",
    "react-dom": "^18.3.1",
    "tsup": "^6.7.0",
    "typescript": "^5.0.4",
    "vitest": "^4.1.4"
  }
}